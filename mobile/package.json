{
  "name": "sync-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "@notifee/react-native": "^7.8.2",
    "@react-native-community/netinfo": "^11.3.2",
    "@react-native-firebase/app": "^18.7.3",
    "@react-native-firebase/messaging": "^18.7.3",
    "react-native": "0.73.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/react-native": "^0.73.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleNameMapper": {
      "@react-native-firebase/messaging": "<rootDir>/src/push/__mocks__/messaging.ts",
      "@react-native-community/netinfo": "<rootDir>/src/sync/__mocks__/netinfo.ts"
